---
const marcqEnBaroeulPathLogo = "/assets/marcq-logo.png";
const cofidisPathLogo = "/assets/cofidis.png";
const cravatePathLogo = "/assets/cravate-solidaire.png";
---

<section class="partners-section">
  <h2>Nos partenaires</h2>
  <div class="partners-grid">
    <div class="partner-card">
      <img src={marcqEnBaroeulPathLogo} alt="Logo Marcq-en-Barœul" />
    </div>
    <div class="partner-card">
      <img src={cofidisPathLogo} alt="Logo Cofidis" />
    </div>
    <div class="partner-card">
      <img src={cravatePathLogo} alt="Logo La Cravate Solidaire Lille" />
    </div>
  </div>
</section>

<style>
  .partners-section {
    padding: clamp(2rem, 6vh, 4rem) 0;
    background-color: #ffffff;
  }

  h2 {
    position: relative;
    text-align: left;
    left: 5%;
    color: #D52151;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 100;
    width: fit-content;
    margin: clamp(30px, 5vh, 50px) 0 clamp(2rem, 5vh, 4rem);
    padding-bottom: 1rem;
    border-bottom: 2px solid currentColor;
  }

  .partners-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    align-items: center;
    justify-items: center;
  }

  .partner-card {
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .partner-card:hover {
    transform: scale(1.05);
  }

  .partner-card img {
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  @media (max-width: 1024px) {
    h2 {
      text-align: center;
      margin: clamp(30px, 5vh, 50px) auto clamp(2rem, 5vh, 4rem);
    }
  }

  @media (max-width: 768px) {
    .partners-grid {
      grid-template-columns: 1fr;
    }
    
    h2 {
      left: 0;
      text-align: center;
      margin: clamp(20px, 4vh, 30px) auto clamp(1rem, 4vh, 2rem);
      font-size: clamp(1.8rem, 6vw, 2.2rem);
    }
  }
</style>
