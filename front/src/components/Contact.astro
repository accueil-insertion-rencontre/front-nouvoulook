---
const imageBoutiquePath = "/assets/boutique.png";
---
  
  <div class="hero-content">
    <div class="text-overlay">
      <h1>Nous contacter</h1>
    </div>
    <img src={imageBoutiquePath} alt="Boutique Nouvoulook" class="hero-image" />
  </div>
</div>
<div class="container py-5">
  <h2 class="text-danger text-center mb-4" style="font-size:2.5rem; font-weight: 600;">Veuillez remplir le formulaire<br>ci-dessous :</h2>
  <form>
    <div class="mb-3">
      <label for="nom" class="form-label">Nom</label>
      <input type="text" class="form-control" id="nom" name="nom" required>
    </div>
    <div class="mb-3">
      <label for="prenom" class="form-label">Prénom</label>
      <input type="text" class="form-control" id="prenom" name="prenom" required>
    </div>
    <div class="mb-3">
      <label for="email" class="form-label">Adresse email</label>
      <input type="email" class="form-control" id="email" name="email" required>
    </div>
    <div class="mb-3">
      <label for="telephone" class="form-label">N° de téléphone <i><small>(optionnel)</small></i></label>
      <input type="tel" class="form-control" id="telephone" name="telephone">
    </div>
    <div class="mb-3">
      <label for="message" class="form-label">Votre message :</label>
      <textarea class="form-control" id="message" name="message" rows="8" required></textarea>
    </div>
    <button type="submit" class="btn btn-primary w-100" style="font-size:1.3rem;">Envoyer</button>
  </form>
</div>

<style>

  .hero-content {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    left: 23%;
    top: 0;
    width: 70%;
    height: 85%;
    border-radius: 10%;
    object-fit: cover;
    padding: 2rem;
  }

  .text-overlay {
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    right: 45%;
    top: 45%;
    background-color: #FAFF63;
    padding: 2.5rem;
    border-radius: 30px;
    width: 45%;
    height: 40%;
    z-index: 1000;
  }

  .text-overlay h1 {
    color: rgb(0, 0, 0);
    font-size: 3.5rem;
    align-items: left;
    margin: 0;
    font-weight: 150;
  }

</style>