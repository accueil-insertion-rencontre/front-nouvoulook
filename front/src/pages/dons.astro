---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import '../style/dons.css';
import HorairesOuverture from '../components/HorairesOuverture.astro';
import InfoDons from '../components/InfoDons.astro';
---

<Layout title="Faire un don">
  <Header />
  <main class="container-fluid py-5 dons-main-with-wave position-relative p-5">
    <div class="dons-bg-wave">
      <svg viewBox="0 0 1440 220" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path fill="#fff9c4" fill-opacity="1" d="M0,160 C360,2040 1080,80 1440,160 L1440,0 L0,0 Z"></path>
      </svg>
    </div>
    <div class="row justify-content-center align-items-center gy-4 mb-4 position-relative dons-hero-row">
      <div class="col-md-6 position-relative">
        <div class="dons-yellow-box dons-overlap p-4">
          <h2 class="mb-0 dons-yellow-title">Vous souhaitez effectuer un don ?</h2>
        </div>
      </div>
      <div class="col-md-6 text-center position-relative">
        <img
          src="/assets/dons.jpg"
          alt="Donner des vêtements"
          class="img-fluid rounded dons-img-real mx-auto mb-2"
          id="don-img"
        />
      </div>
    </div>
    <HorairesOuverture
      icone="⏰"
      texte="Nouvoulook vous accueille du mardi au vendredi matin de 9h à 12h ! Ainsi que le samedi après midi de 14h à 18h."
      texteItalique="Fermé les dimanches et les lundis."
    />
    <InfoDons
      icone="🤲"
      texte={`Nous vous remercions chaleureusement pour votre <span class='dons-highlight'>générosité</span>.<br>Chaque don compte et contribue à aider ceux qui en ont <span class='dons-highlight'>besoin</span>.<br>Cependant, nous vous rappelons que nous ne sommes pas une <span class='dons-highlight'>décharge</span>.<br>Merci de ne donner que des vêtements <span class='dons-highlight'>propres</span>, en <span class='dons-highlight'>bon état</span>, et dignes d'être portés.`}
    />
  </main>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const img = document.getElementById('don-img');
    if (img) {
      img.addEventListener('load', () => {
        img.classList.add('loaded');
      });
      // Si l'image est déjà dans le cache
      if (img.complete) {
        img.classList.add('loaded');
      }
    }
  });
</script>